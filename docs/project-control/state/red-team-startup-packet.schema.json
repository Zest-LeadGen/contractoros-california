{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Zest-LeadGen/contractoros-california/blob/main/docs/project-control/state/red-team-startup-packet.schema.json",
  "title": "ContractorOS structured red-team startup packet",
  "type": "object",
  "required": ["schema_version", "generator_version", "observed_at", "repository", "canonical_schema_version", "source_shas", "issue", "pr", "checks", "workflow_run", "markers", "review", "auto_merge", "classification", "quarantine", "findings", "blockers", "missing_evidence", "next_action", "stop_conditions", "prohibited_actions", "evidence_classification", "derived_status"],
  "properties": {
    "schema_version": {"const": "1.3.5"},
    "generator_version": {"type": "string", "minLength": 1},
    "observed_at": {"type": "string", "format": "date-time"},
    "repository": {"$ref": "#/$defs/repository"},
    "canonical_schema_version": {"type": "string", "minLength": 1},
    "source_shas": {"$ref": "#/$defs/sourceShas"},
    "issue": {"$ref": "#/$defs/issue"},
    "pr": {"$ref": "#/$defs/pr"},
    "checks": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/check"}},
    "workflow_run": {"$ref": "#/$defs/workflowRun"},
    "markers": {"$ref": "#/$defs/markers"},
    "review": {"$ref": "#/$defs/review"},
    "auto_merge": {"$ref": "#/$defs/autoMerge"},
    "classification": {"enum": ["consistent", "requires_live_verification", "stale", "blocked", "quarantined"]},
    "quarantine": {"type": "boolean"},
    "findings": {"$ref": "#/$defs/uniqueStrings"},
    "blockers": {"$ref": "#/$defs/uniqueStrings"},
    "missing_evidence": {"$ref": "#/$defs/uniqueStrings"},
    "next_action": {"type": "string", "minLength": 1},
    "stop_conditions": {"$ref": "#/$defs/uniqueStrings"},
    "prohibited_actions": {"$ref": "#/$defs/uniqueStrings"},
    "evidence_classification": {"const": "public_safe"},
    "derived_status": {"const": "no authority"}
  },
  "$defs": {
    "sha": {"anyOf": [{"type": "null"}, {"type": "string", "pattern": "^[0-9a-f]{40}$"}]},
    "uniqueStrings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "repository": {
      "type": "object",
      "required": ["requested_name", "name", "default_branch", "remote_name", "remote_transport", "root_verified", "remote_verified", "remote_identifier"],
      "properties": {
        "requested_name": {"const": "Zest-LeadGen/contractoros-california"},
        "name": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "default_branch": {"type": "string", "minLength": 1},
        "remote_name": {"type": "string", "minLength": 1},
        "remote_transport": {"enum": ["https", "ssh", "unsupported"]},
        "root_verified": {"type": "boolean"},
        "remote_verified": {"type": "boolean"},
        "remote_identifier": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "sourceShas": {
      "type": "object",
      "required": ["local_head", "local_main", "local_origin_main", "live_default_branch", "canonical_ref", "worktree_clean_before", "worktree_clean_after", "worktree_status_unchanged", "worktree_status_before_sha256", "worktree_status_after_sha256", "worktree_head_before", "worktree_head_after", "worktree_head_unchanged"],
      "properties": {
        "local_head": {"$ref": "#/$defs/sha"}, "local_main": {"$ref": "#/$defs/sha"},
        "local_origin_main": {"$ref": "#/$defs/sha"}, "live_default_branch": {"$ref": "#/$defs/sha"},
        "canonical_ref": {"$ref": "#/$defs/sha"}, "worktree_clean_before": {"const": true},
        "worktree_clean_after": {"const": true}, "worktree_status_unchanged": {"const": true},
        "worktree_status_before_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "worktree_status_after_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "worktree_head_before": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "worktree_head_after": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "worktree_head_unchanged": {"const": true}
      },
      "additionalProperties": false
    },
    "issue": {
      "type": "object", "required": ["number", "state", "state_reason", "url", "closeout_state"],
      "properties": {"number": {"type": "integer", "minimum": 1}, "state": {"enum": ["open", "active", "closed"]}, "state_reason": {"anyOf": [{"type": "null"}, {"type": "string"}]}, "url": {"type": "string", "format": "uri"}, "closeout_state": {"enum": ["open", "closed"]}},
      "additionalProperties": false
    },
    "pr": {
      "type": "object", "required": ["number", "state", "base", "head_branch", "head", "draft", "merge_commit", "merged_at", "url", "author_login", "author_type"], "description": "scope-bound PR identity evidence",
      "properties": {"number": {"type": "integer", "minimum": 1}, "state": {"enum": ["open", "closed", "merged"]}, "base": {"type": "string", "minLength": 1}, "head_branch": {"type": "string", "minLength": 1}, "head": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "draft": {"type": "boolean"}, "merge_commit": {"$ref": "#/$defs/sha"}, "merged_at": {"anyOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]}, "url": {"type": "string", "format": "uri"}, "author_login": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$"}, "author_type": {"enum": ["User", "Bot"]}}, "description": "scope-bound PR identity properties",
      "additionalProperties": false
    },
    "check": {"type": "object", "required": ["name", "state", "bucket", "link"], "properties": {"name": {"type": "string"}, "state": {"type": "string"}, "bucket": {"type": "string"}, "link": {"type": "string", "format": "uri"}}, "additionalProperties": false},
    "step": {"type": "object", "required": ["name", "number", "status", "conclusion"], "properties": {"name": {"type": "string"}, "number": {"type": "integer", "minimum": 1}, "status": {"type": "string", "minLength": 1}, "conclusion": {"anyOf": [{"type": "null"}, {"type": "string"}]}}, "additionalProperties": false},
    "job": {"type": "object", "required": ["name", "status", "conclusion", "steps"], "properties": {"name": {"type": "string", "minLength": 1}, "status": {"type": "string", "minLength": 1}, "conclusion": {"anyOf": [{"type": "null"}, {"type": "string"}]}, "steps": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/step"}}}, "additionalProperties": false},
    "workflowRun": {"type": "object", "required": ["id", "name", "workflow_id", "event", "status", "conclusion", "head_sha", "head_branch", "url", "jobs"], "properties": {"id": {"type": "integer", "minimum": 1}, "name": {"type": "string", "minLength": 1}, "workflow_id": {"type": "integer", "minimum": 1}, "event": {"type": "string", "minLength": 1}, "status": {"type": "string", "minLength": 1}, "conclusion": {"anyOf": [{"type": "null"}, {"type": "string"}]}, "head_sha": {"$ref": "#/$defs/sha"}, "head_branch": {"type": "string", "minLength": 1}, "url": {"type": "string", "format": "uri"}, "jobs": {"type": "array", "maxItems": 25, "items": {"$ref": "#/$defs/job"}}}, "additionalProperties": false},
    "markers": {"type": "object", "required": ["owner_trigger_status", "red_team_status", "red_team_bound_sha"], "properties": {"owner_trigger_status": {"enum": ["valid", "missing_or_invalid"]}, "red_team_status": {"enum": ["valid", "missing", "stale"]}, "red_team_bound_sha": {"$ref": "#/$defs/sha"}}, "additionalProperties": false},
    "reviewRecord": {"type": "object", "required": ["review_id", "reviewer_login", "reviewer_type", "state", "submitted_at", "commit_id", "author_association"], "properties": {"review_id": {"type": "integer", "minimum": 1}, "reviewer_login": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$"}, "reviewer_type": {"enum": ["User", "Bot"]}, "state": {"enum": ["APPROVED", "CHANGES_REQUESTED", "DISMISSED", "COMMENTED", "PENDING"]}, "submitted_at": {"anyOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]}, "commit_id": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "author_association": {"type": "string", "maxLength": 100}}, "additionalProperties": false, "description": "scope-bound review identity evidence"},
    "permissionRecord": {"type": "object", "required": ["reviewer_login", "permission", "role_name", "account_type"], "properties": {"reviewer_login": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$"}, "permission": {"enum": ["admin", "write", "read", "none", "triage"]}, "role_name": {"type": "string", "minLength": 1, "maxLength": 100}, "account_type": {"enum": ["User", "Bot"]}}, "additionalProperties": false, "description": "scope-bound permission identity evidence"},
    "review": {"type": "object", "required": ["decision", "evidence_status", "review_records", "permission_records", "qualifying_approvals", "disqualified_approvals", "disqualification_reasons"], "properties": {"decision": {"anyOf": [{"type": "null"}, {"enum": ["APPROVED", "CHANGES_REQUESTED", "REVIEW_REQUIRED"]}]}, "evidence_status": {"enum": ["complete", "truncated", "unavailable"]}, "review_records": {"type": "array", "maxItems": 500, "items": {"$ref": "#/$defs/reviewRecord"}}, "permission_records": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/permissionRecord"}}, "qualifying_approvals": {"type": "array", "maxItems": 100, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$"}}, "disqualified_approvals": {"type": "array", "maxItems": 100, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$"}}, "disqualification_reasons": {"type": "object", "description": "scope-bound approval reason evidence", "maxProperties": 100, "patternProperties": {"^(?:_evidence|[A-Za-z0-9][A-Za-z0-9-]{0,38})$": {"type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true, "items": {"enum": ["APPROVAL_REVIEW_RECORD_MALFORMED", "APPROVAL_STALE_HEAD", "APPROVAL_SUPERSEDED_BY_CHANGES_REQUESTED", "APPROVAL_DISMISSED", "APPROVAL_NOT_SUBMITTED", "APPROVAL_BOT_ACCOUNT", "APPROVAL_PR_AUTHOR", "APPROVAL_PERMISSION_EVIDENCE_MISSING", "APPROVAL_PERMISSION_IDENTITY_MISMATCH", "APPROVAL_PERMISSION_READ_ONLY", "APPROVAL_PERMISSION_NONE", "APPROVAL_PERMISSION_UNKNOWN"]}}}, "additionalProperties": false}}, "additionalProperties": false},
    "autoMerge": {"type": "object", "required": ["active"], "properties": {"active": {"type": "boolean"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
