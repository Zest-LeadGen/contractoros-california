{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Zest-LeadGen/contractoros-california/blob/main/docs/project-control/state/red-team-continuity-evidence.schema.json",
  "title": "ContractorOS red-team continuity evidence",
  "type": "object",
  "required": ["schema_version", "generator_version", "observed_at", "repository", "source_shas", "source_commands", "canonical_state", "actor_contract", "actor_contract_result", "live_state", "comparison_findings", "blockers", "missing_evidence", "consistency_classification", "quarantine", "public_private_classification", "packet_hash", "packet_hash_rule", "startup_packet"],
  "properties": {
    "schema_version": {"const": "1.4.0"},
    "generator_version": {"type": "string", "minLength": 1},
    "observed_at": {"type": "string", "format": "date-time"},
    "repository": {"$ref": "#/$defs/repository"},
    "source_shas": {"$ref": "#/$defs/sourceShas"},
    "source_commands": {"type": "array", "maxItems": 119, "items": {"$ref": "#/$defs/commandResult"}},
    "canonical_state": {"$ref": "#/$defs/canonicalState"},
    "actor_contract": {"$ref": "#/$defs/actorContract"},
    "actor_contract_result": {"$ref": "#/$defs/roleContractResult"},
    "live_state": {"$ref": "#/$defs/liveState"},
    "comparison_findings": {"$ref": "#/$defs/uniqueStrings"},
    "blockers": {"$ref": "#/$defs/uniqueStrings"},
    "missing_evidence": {"$ref": "#/$defs/uniqueStrings"},
    "consistency_classification": {"$ref": "#/$defs/classification"},
    "quarantine": {"type": "boolean"},
    "public_private_classification": {"const": "public_safe"},
    "packet_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "packet_hash_rule": {"type": "string", "minLength": 1},
    "startup_packet": {"$ref": "red-team-startup-packet.schema.json"}
  },
  "$defs": {
    "sha": {"anyOf": [{"type": "null"}, {"type": "string", "pattern": "^[0-9a-f]{40}$"}]},
    "requiredSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "classification": {"enum": ["consistent", "requires_live_verification", "stale", "blocked", "quarantined"]},
    "uniqueStrings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "authorityProfile": {"$comment": "Stage A scope",
      "type": "object",
      "title": "Stage A scope profile", "required": ["DEVELOPER_ROLE", "REPOSITORY_WRITE_AUTHORITY", "GITHUB_WRITE_AUTHORITY", "TERMINAL_MUTATION_AUTHORITY", "IMPLEMENTATION_AUTHORITY", "PROMPT_AUTHORING_AUTHORITY", "EXACT_SHA_REVIEW_AUTHORITY", "HUMAN_APPROVAL_AUTHORITY", "MERGE_AUTHORITY", "ISSUE_CLOSEOUT_AUTHORITY"],
      "properties": {
        "DEVELOPER_ROLE": {"enum": ["SEPARATE", "SELF"]},
        "REPOSITORY_WRITE_AUTHORITY": {"$comment": "scope", "enum": ["NONE", "BOUNDED"]},
        "GITHUB_WRITE_AUTHORITY": {"$comment": "scope", "enum": ["NONE", "PR_ONLY", "APPROVAL_ONLY", "MERGE_ONLY"]},
        "TERMINAL_MUTATION_AUTHORITY": {"$comment": "scope", "enum": ["NONE", "BOUNDED"]},
        "IMPLEMENTATION_AUTHORITY": {"$comment": "scope", "enum": ["YES", "NO"]},
        "PROMPT_AUTHORING_AUTHORITY": {"$comment": "scope", "enum": ["YES", "NO"]},
        "EXACT_SHA_REVIEW_AUTHORITY": {"$comment": "scope", "enum": ["YES", "NO"]},
        "HUMAN_APPROVAL_AUTHORITY": {"$comment": "scope", "enum": ["YES", "NO"]},
        "MERGE_AUTHORITY": {"$comment": "scope", "enum": ["YES", "NO"]},
        "ISSUE_CLOSEOUT_AUTHORITY": {"$comment": "scope", "enum": ["YES", "NO"]}
      },
      "additionalProperties": false
    },
    "actorContract": {"$comment": "Stage A scope",
      "type": "object",
      "title": "Stage A scope contract", "required": ["ACTOR_ROLE", "ROLE", "REPOSITORY", "ISSUE", "PULL_REQUEST", "BRANCH", "EXACT_SHA", "LIFECYCLE_STATE", "AUTHORITY_SOURCE", "OBSERVATION_TIMESTAMP", "PROGRAM_NEXT_ACTION", "NEXT_AUTHORIZED_ACTOR", "DEVELOPER_NEXT_ACTION", "RED_TEAM_NEXT_ACTION", "HUMAN_APPROVER_NEXT_ACTION", "MERGE_OPERATOR_NEXT_ACTION", "REQUESTED_ACTION_CLASS", "DEVELOPER_ROLE", "REPOSITORY_WRITE_AUTHORITY", "GITHUB_WRITE_AUTHORITY", "TERMINAL_MUTATION_AUTHORITY", "IMPLEMENTATION_AUTHORITY", "PROMPT_AUTHORING_AUTHORITY", "EXACT_SHA_REVIEW_AUTHORITY", "HUMAN_APPROVAL_AUTHORITY", "MERGE_AUTHORITY", "ISSUE_CLOSEOUT_AUTHORITY"],
      "properties": {
        "ACTOR_ROLE": {"enum": ["CODEX_DEVELOPER", "RED_TEAM", "HUMAN_APPROVER", "MERGE_OPERATOR"]},
        "ROLE": {"enum": ["CODEX_DEVELOPER", "RED_TEAM", "HUMAN_APPROVER", "MERGE_OPERATOR"]},
        "REPOSITORY": {"const": "Zest-LeadGen/contractoros-california"},
        "ISSUE": {"type": "integer", "minimum": 1}, "PULL_REQUEST": {"type": "integer", "minimum": 1},
        "BRANCH": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,199}$"},
        "EXACT_SHA": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "LIFECYCLE_STATE": {"enum": ["DEVELOPER_IMPLEMENTATION_IN_REVIEW", "EXTERNAL_EXACT_SHA_REVIEW", "HUMAN_APPROVAL_PENDING", "MERGE_PENDING", "MERGED_MAIN_VERIFICATION_PENDING", "PHASE_CLOSED_READY_FOR_NEXT_PHASE", "BLOCKED", "QUARANTINED"]},
        "AUTHORITY_SOURCE": {"$comment": "scope", "enum": ["GITHUB_ISSUE_49", "GITHUB_ISSUE_55", "GITHUB_PULL_REQUEST", "OWNER_APPROVED_GITHUB_ISSUE", "VERSIONED_PROJECT_CONTROL"]},
        "OBSERVATION_TIMESTAMP": {"type": "string", "format": "date-time"},
        "PROGRAM_NEXT_ACTION": {"type": "string", "minLength": 1, "maxLength": 240},
        "NEXT_AUTHORIZED_ACTOR": {"$comment": "scope", "enum": ["CODEX_DEVELOPER", "RED_TEAM", "HUMAN_APPROVER", "MERGE_OPERATOR", "NONE"]},
        "DEVELOPER_NEXT_ACTION": {"enum": ["NONE", "IMPLEMENT_ISSUE_55_STAGE_A", "CORRECT_ISSUE_55_PR"]},
        "RED_TEAM_NEXT_ACTION": {"$comment": "scope", "enum": ["NONE", "AUTHOR_BOUNDED_DEVELOPER_PROMPT", "REVIEW_EXACT_SHA"]},
        "HUMAN_APPROVER_NEXT_ACTION": {"enum": ["NONE", "REVIEW_FOR_HUMAN_APPROVAL"]},
        "MERGE_OPERATOR_NEXT_ACTION": {"enum": ["NONE", "MERGE_AFTER_ALL_GATES"]},
        "REQUESTED_ACTION_CLASS": {"$comment": "scope", "enum": ["NONE", "PROMPT_AUTHORING", "EXACT_SHA_REVIEW", "REPOSITORY_MUTATION", "GITHUB_MUTATION", "TERMINAL_MUTATION", "IMPLEMENTATION", "REVIEW_SUBMISSION", "HUMAN_APPROVAL", "MERGE", "ISSUE_CLOSEOUT", "CREDENTIAL_CHANGE", "SPENDING", "DEPLOYMENT", "RELEASE"]},
        "DEVELOPER_ROLE": {"enum": ["SEPARATE", "SELF"]},
        "REPOSITORY_WRITE_AUTHORITY": {"enum": ["NONE", "BOUNDED"]}, "GITHUB_WRITE_AUTHORITY": {"enum": ["NONE", "PR_ONLY", "APPROVAL_ONLY", "MERGE_ONLY"]}, "TERMINAL_MUTATION_AUTHORITY": {"enum": ["NONE", "BOUNDED"], "$comment": "scope"},
        "IMPLEMENTATION_AUTHORITY": {"enum": ["YES", "NO"]}, "PROMPT_AUTHORING_AUTHORITY": {"enum": ["YES", "NO"]}, "EXACT_SHA_REVIEW_AUTHORITY": {"enum": ["YES", "NO"]}, "HUMAN_APPROVAL_AUTHORITY": {"enum": ["YES", "NO"]}, "MERGE_AUTHORITY": {"enum": ["YES", "NO"]}, "ISSUE_CLOSEOUT_AUTHORITY": {"enum": ["YES", "NO"], "$comment": "scope"}
      },
      "allOf": [{
        "if": {"properties": {"ACTOR_ROLE": {"const": "RED_TEAM"}}, "required": ["ACTOR_ROLE"]},
        "then": {"properties": {
          "ROLE": {"const": "RED_TEAM"}, "DEVELOPER_ROLE": {"const": "SEPARATE"},
          "REPOSITORY_WRITE_AUTHORITY": {"const": "NONE"}, "GITHUB_WRITE_AUTHORITY": {"const": "NONE"}, "TERMINAL_MUTATION_AUTHORITY": {"const": "NONE", "$comment": "scope"},
          "IMPLEMENTATION_AUTHORITY": {"const": "NO"}, "PROMPT_AUTHORING_AUTHORITY": {"const": "YES"}, "EXACT_SHA_REVIEW_AUTHORITY": {"const": "YES", "$comment": "scope"},
          "HUMAN_APPROVAL_AUTHORITY": {"const": "NO"}, "MERGE_AUTHORITY": {"const": "NO"}, "ISSUE_CLOSEOUT_AUTHORITY": {"const": "NO", "$comment": "scope"}
        }}
      }],
      "additionalProperties": false
    },
    "roleContractResult": {"$comment": "Stage A scope",
      "type": "object",
      "title": "Stage A scope result", "required": ["schema_version", "valid", "decision", "actor_role", "role_conflict_status", "role_repair_state", "reasons", "program_next_action_is_authority", "next_authorized_actor", "next_actions", "effective_authority", "incident", "bounded_claim"],
      "properties": {
        "schema_version": {"const": "1.0.0"}, "valid": {"type": "boolean"}, "decision": {"enum": ["ALLOW", "DENY"]},
        "actor_role": {"enum": ["CODEX_DEVELOPER", "RED_TEAM", "HUMAN_APPROVER", "MERGE_OPERATOR", "UNKNOWN"]},
        "role_conflict_status": {"enum": ["NORMAL", "ROLE_CONFLICT"]}, "role_repair_state": {"enum": ["NORMAL", "REPAIR_REQUIRED", "READ_ONLY_ROLE_RESTORED"]},
        "reasons": {"$ref": "#/$defs/uniqueStrings"}, "program_next_action_is_authority": {"const": false, "$comment": "scope"},
        "next_authorized_actor": {"enum": ["CODEX_DEVELOPER", "RED_TEAM", "HUMAN_APPROVER", "MERGE_OPERATOR", "NONE"], "$comment": "scope"},
        "next_actions": {"type": "object", "required": ["CODEX_DEVELOPER", "RED_TEAM", "HUMAN_APPROVER", "MERGE_OPERATOR"], "properties": {"CODEX_DEVELOPER": {"enum": ["NONE", "IMPLEMENT_ISSUE_55_STAGE_A", "CORRECT_ISSUE_55_PR"]}, "RED_TEAM": {"enum": ["NONE", "AUTHOR_BOUNDED_DEVELOPER_PROMPT", "REVIEW_EXACT_SHA"]}, "HUMAN_APPROVER": {"enum": ["NONE", "REVIEW_FOR_HUMAN_APPROVAL"]}, "MERGE_OPERATOR": {"enum": ["NONE", "MERGE_AFTER_ALL_GATES"]}}, "additionalProperties": false, "$comment": "scope"},
        "effective_authority": {"$ref": "#/$defs/authorityProfile", "$comment": "scope"},
        "incident": {"anyOf": [{"type": "null"}, {"type": "object", "required": ["actor", "observation_timestamp", "requested_action_class", "lifecycle_state", "authority_source", "result", "denial_reasons", "required_repair_state"], "properties": {"actor": {"const": "RED_TEAM"}, "observation_timestamp": {"type": "string"}, "requested_action_class": {"type": "string"}, "lifecycle_state": {"type": "string"}, "authority_source": {"type": "string"}, "result": {"const": "DENIED"}, "denial_reasons": {"$ref": "#/$defs/uniqueStrings"}, "required_repair_state": {"const": "REPAIR_REQUIRED"}}, "additionalProperties": false}], "$comment": "scope"},
        "bounded_claim": {"type": "object", "required": ["actor_bound_role_contract", "full_runtime_isolation", "stage_b_required"], "properties": {"actor_bound_role_contract": {"const": "IMPLEMENTED_IN_REVIEW"}, "full_runtime_isolation": {"const": "NOT_PROVEN"}, "stage_b_required": {"const": "YES"}}, "additionalProperties": false}
      },
      "additionalProperties": false
    },
    "canonicalLinkedIssue": {
      "type": "object",
      "required": ["number", "state"],
      "properties": {
        "number": {"type": "integer", "minimum": 1},
        "state": {"enum": ["active", "open", "closed_completed", "closed_not_planned"]}
      },
      "additionalProperties": false
    },
    "canonicalLinkedPr": {
      "type": "object",
      "required": ["number", "state", "observed_head_sha"],
      "properties": {
        "number": {"type": "integer", "minimum": 1},
        "state": {"enum": ["open", "closed", "merged"]},
        "url": {"type": "string", "format": "uri"},
        "head_sha_source": {"const": "live_github_required"},
        "observed_head_sha": {"$ref": "#/$defs/sha"}
      },
      "additionalProperties": false
    },
    "canonicalState": {
      "type": "object",
      "required": ["schema_version", "snapshot_semantics", "current_main_sha", "linked_issue", "linked_pr", "lifecycle_state", "consistency_status"],
      "properties": {
        "schema_version": {"type": "string", "minLength": 1},
        "snapshot_semantics": {"const": "observed_snapshot_requires_live_verification"},
        "current_main_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "linked_issue": {"$ref": "#/$defs/canonicalLinkedIssue"},
        "linked_pr": {"$ref": "#/$defs/canonicalLinkedPr"},
        "lifecycle_state": {"type": "string", "minLength": 1},
        "consistency_status": {"$ref": "#/$defs/classification"}
      },
      "additionalProperties": true
    },
    "repository": {
      "type": "object",
      "required": ["requested_name", "name", "default_branch", "remote_name", "remote_transport", "root_verified", "remote_verified", "remote_identifier"],
      "properties": {
        "requested_name": {"const": "Zest-LeadGen/contractoros-california"},
        "name": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "default_branch": {"type": "string", "minLength": 1},
        "remote_name": {"type": "string", "minLength": 1},
        "remote_transport": {"enum": ["https", "ssh", "unsupported"]},
        "root_verified": {"type": "boolean"},
        "remote_verified": {"type": "boolean"},
        "remote_identifier": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "sourceShas": {
      "type": "object",
      "required": ["local_head", "local_main", "local_origin_main", "live_default_branch", "canonical_ref", "worktree_clean_before", "worktree_clean_after", "worktree_status_unchanged", "worktree_status_before_sha256", "worktree_status_after_sha256", "worktree_head_before", "worktree_head_after", "worktree_head_unchanged"],
      "properties": {
        "local_head": {"$ref": "#/$defs/sha"},
        "local_main": {"$ref": "#/$defs/sha"},
        "local_origin_main": {"$ref": "#/$defs/sha"},
        "live_default_branch": {"$ref": "#/$defs/sha"},
        "canonical_ref": {"$ref": "#/$defs/requiredSha"},
        "worktree_clean_before": {"const": true},
        "worktree_clean_after": {"const": true},
        "worktree_status_unchanged": {"const": true},
        "worktree_status_before_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "worktree_status_after_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "worktree_head_before": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "worktree_head_after": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "worktree_head_unchanged": {"const": true}
      },
      "additionalProperties": false
    },
    "commandResult": {
      "type": "object",
      "required": ["argv", "return_code", "stdout_sha256", "stderr_present"],
      "properties": {
        "argv": {"type": "array", "minItems": 2, "maxItems": 32, "items": {"type": "string", "minLength": 1}},
        "return_code": {"const": 0},
        "stdout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "stderr_present": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "issue": {
      "type": "object",
      "required": ["number", "state", "state_reason", "url", "closeout_state"],
      "properties": {
        "number": {"type": "integer", "minimum": 1},
        "state": {"enum": ["open", "active", "closed"]},
        "state_reason": {"anyOf": [{"type": "null"}, {"type": "string"}]},
        "url": {"type": "string", "format": "uri"},
        "closeout_state": {"enum": ["open", "closed"]}
      },
      "additionalProperties": false
    },
    "pr": {
      "type": "object",
      "required": ["number", "state", "base", "head_branch", "head", "draft", "merge_commit", "merged_at", "url", "author_login", "author_type"], "description": "scope-bound PR identity evidence",
      "properties": {
        "number": {"type": "integer", "minimum": 1},
        "state": {"enum": ["open", "closed", "merged"]},
        "base": {"type": "string", "minLength": 1},
        "head_branch": {"type": "string", "minLength": 1},
        "head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "draft": {"type": "boolean"},
        "merge_commit": {"$ref": "#/$defs/sha"},
        "merged_at": {"anyOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
        "url": {"type": "string", "format": "uri"},
        "author_login": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$", "description": "scope-bound PR identity"},
        "author_type": {"enum": ["User", "Bot"], "description": "scope-bound PR identity"}
      },
      "additionalProperties": false
    },
    "check": {
      "type": "object",
      "required": ["name", "state", "bucket", "link"],
      "properties": {
        "name": {"type": "string"},
        "state": {"type": "string"},
        "bucket": {"type": "string"},
        "link": {"type": "string", "format": "uri"}
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": ["name", "number", "status", "conclusion"],
      "properties": {
        "name": {"type": "string"},
        "number": {"type": "integer", "minimum": 1},
        "status": {"type": "string", "minLength": 1},
        "conclusion": {"anyOf": [{"type": "null"}, {"type": "string"}]}
      },
      "additionalProperties": false
    },
    "job": {
      "type": "object",
      "required": ["name", "status", "conclusion", "steps"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "status": {"type": "string", "minLength": 1},
        "conclusion": {"anyOf": [{"type": "null"}, {"type": "string"}]},
        "steps": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/step"}}
      },
      "additionalProperties": false
    },
    "workflowRun": {
      "type": "object",
      "required": ["id", "name", "workflow_id", "event", "status", "conclusion", "head_sha", "head_branch", "url", "jobs"],
      "properties": {
        "id": {"type": "integer", "minimum": 1},
        "name": {"type": "string", "minLength": 1},
        "workflow_id": {"type": "integer", "minimum": 1},
        "event": {"type": "string", "minLength": 1},
        "status": {"type": "string", "minLength": 1},
        "conclusion": {"anyOf": [{"type": "null"}, {"type": "string"}]},
        "head_sha": {"$ref": "#/$defs/sha"},
        "head_branch": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri"},
        "jobs": {"type": "array", "maxItems": 25, "items": {"$ref": "#/$defs/job"}}
      },
      "additionalProperties": false
    },
    "markers": {
      "type": "object",
      "required": ["owner_trigger_status", "red_team_status", "red_team_bound_sha"],
      "properties": {
        "owner_trigger_status": {"enum": ["valid", "missing_or_invalid"]},
        "red_team_status": {"enum": ["valid", "missing", "stale"]},
        "red_team_bound_sha": {"$ref": "#/$defs/sha"}
      },
      "additionalProperties": false
    },
    "reviewRecord": {
      "type": "object",
      "required": ["review_id", "reviewer_login", "reviewer_type", "state", "submitted_at", "commit_id", "author_association"], "description": "scope-bound review identity evidence",
      "properties": {
        "review_id": {"type": "integer", "minimum": 1},
        "reviewer_login": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$", "description": "scope-bound reviewer identity"},
        "reviewer_type": {"enum": ["User", "Bot"]},
        "state": {"enum": ["APPROVED", "CHANGES_REQUESTED", "DISMISSED", "COMMENTED", "PENDING"]},
        "submitted_at": {"anyOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
        "commit_id": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "author_association": {"type": "string", "maxLength": 100, "description": "scope-bound review metadata"}
      },
      "additionalProperties": false
    },
    "permissionRecord": {
      "type": "object",
      "required": ["reviewer_login", "permission", "role_name", "account_type"], "description": "scope-bound permission identity evidence",
      "properties": {
        "reviewer_login": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$", "description": "scope-bound reviewer identity"},
        "permission": {"enum": ["admin", "write", "read", "none", "triage"]},
        "role_name": {"type": "string", "minLength": 1, "maxLength": 100},
        "account_type": {"enum": ["User", "Bot"]}
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "required": ["decision", "evidence_status", "review_records", "permission_records", "qualifying_approvals", "disqualified_approvals", "disqualification_reasons"],
      "properties": {
        "decision": {"anyOf": [{"type": "null"}, {"enum": ["APPROVED", "CHANGES_REQUESTED", "REVIEW_REQUIRED"]}]},
        "evidence_status": {"enum": ["complete", "truncated", "unavailable"]},
        "review_records": {"type": "array", "maxItems": 500, "items": {"$ref": "#/$defs/reviewRecord"}},
        "permission_records": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/permissionRecord"}},
        "qualifying_approvals": {"type": "array", "maxItems": 100, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$"}},
        "disqualified_approvals": {"type": "array", "maxItems": 100, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}$"}},
        "disqualification_reasons": {"type": "object", "description": "scope-bound approval reason evidence", "maxProperties": 100, "properties": {"_evidence": {"type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true, "items": {"enum": ["APPROVAL_REVIEW_RECORD_MALFORMED"]}}}, "patternProperties": {"^(?!_evidence$)[A-Za-z0-9][A-Za-z0-9-]{0,38}$": {"type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true, "items": {"enum": ["APPROVAL_REVIEW_RECORD_MALFORMED", "APPROVAL_STALE_HEAD", "APPROVAL_SUPERSEDED_BY_CHANGES_REQUESTED", "APPROVAL_DISMISSED", "APPROVAL_NOT_SUBMITTED", "APPROVAL_BOT_ACCOUNT", "APPROVAL_PR_\u0041UTHOR", "APPROVAL_PERMISSION_EVIDENCE_MISSING", "APPROVAL_PERMISSION_IDENTITY_MISMATCH", "APPROVAL_PERMISSION_READ_ONLY", "APPROVAL_PERMISSION_NONE", "APPROVAL_PERMISSION_UNKNOWN"]}}}, "additionalProperties": false}
      },
      "additionalProperties": false
    },
    "autoMerge": {
      "type": "object",
      "required": ["active"],
      "properties": {"active": {"type": "boolean"}},
      "additionalProperties": false
    },
    "liveState": {
      "type": "object",
      "required": ["issue", "pr", "checks", "workflow_run", "markers", "review", "auto_merge"],
      "properties": {
        "issue": {"$ref": "#/$defs/issue"},
        "pr": {"$ref": "#/$defs/pr"},
        "checks": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/check"}},
        "workflow_run": {"$ref": "#/$defs/workflowRun"},
        "markers": {"$ref": "#/$defs/markers"},
        "review": {"$ref": "#/$defs/review"},
        "auto_merge": {"$ref": "#/$defs/autoMerge"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
